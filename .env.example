# LLM Provider (Optional if Ollama is available locally)
GROQ_API_KEY=

# Ollama local settings (used as default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Paths
DATA_DIR=./data/raw
VECTORSTORE_DIR=./vectorstore
CHROMA_COLLECTION_NAME=medisearch_docs

# RAG config
CHUNK_SIZE=512
CHUNK_OVERLAP=50
SIMILARITY_TOP_K=5
